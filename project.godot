; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[ {
"base": "Node",
"class": "Chat",
"language": "GDScript",
"path": "res://objects/chat/chat.gd"
}, {
"base": "Node",
"class": "ChatDialog",
"language": "GDScript",
"path": "res://objects/chat/chat_dialog.gd"
}, {
"base": "Node",
"class": "ChatDialogMessage",
"language": "GDScript",
"path": "res://objects/chat/chat_dialog_message.gd"
}, {
"base": "Node",
"class": "User",
"language": "GDScript",
"path": "res://objects/user/user.gd"
}, {
"base": "Node",
"class": "UserApps",
"language": "GDScript",
"path": "res://objects/user/user_apps.gd"
}, {
"base": "Node",
"class": "UserSettings",
"language": "GDScript",
"path": "res://objects/user/user_settings.gd"
} ]
_global_script_class_icons={
"Chat": "",
"ChatDialog": "",
"ChatDialogMessage": "",
"User": "",
"UserApps": "",
"UserSettings": ""
}

[application]

config/name="os-game"
run/main_scene="res://scenes/main/main.tscn"
config/icon="res://icon.png"

[autoload]

GlobalReference="*res://objects/globals/reference.gd"
Signals="*res://objects/globals/signals.gd"
Core="*res://objects/globals/core.gd"
Data="*res://objects/globals/data.gd"

[display]

window/stretch/mode="2d"
window/stretch/aspect="expand"

[global]

Version=""

[physics]

common/enable_pause_aware_picking=true

[rendering]

quality/driver/driver_name="GLES2"
vram_compression/import_etc=true
vram_compression/import_etc2=false
environment/default_environment="res://default_env.tres"
